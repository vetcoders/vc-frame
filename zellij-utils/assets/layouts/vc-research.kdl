// vc-research — triple-agent research workspace
// Launch: vibecrafted dashboard vc-research
//
// VibeCrafted with AI Agents (c)2026 VetCoders
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar" {
                brand_text " 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. "
                brand_text_short " VC. "
            }
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="Research" {
        pane split_direction="vertical" {
            pane name="synthesis" size="55%" focus=true
            pane split_direction="horizontal" size="45%" {
                pane name="claude"
                pane name="codex"
                pane name="gemini"
            }
        }
    }

    swap_tiled_layout name="grid" {
        tab {
            pane split_direction="horizontal" {
                pane split_direction="vertical" size="50%" {
                    pane name="claude"
                    pane name="codex"
                }
                pane split_direction="vertical" size="50%" {
                    pane name="gemini"
                    pane name="synthesis" focus=true
                }
            }
        }
    }

    swap_tiled_layout name="synthesis" {
        tab {
            pane name="synthesis" focus=true
        }
    }
}
